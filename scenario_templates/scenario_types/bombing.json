{
  "id": "bombing",
  "display_name": "Bombing (open-air / general)",
  "category": "terrorism",
  "required_teams": [
    {
      "team_name": "evacuation",
      "team_description": "Evacuate casualties and bystanders from the blast zone, manage crowd flow and assembly points",
      "min_participants": 2,
      "max_participants": 10
    },
    {
      "team_name": "triage",
      "team_description": "Establish triage near the blast site, prioritize injuries, coordinate ambulance handover",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "media",
      "team_description": "Manage media, counter misinformation, issue public statements",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "fire",
      "team_description": "Fire containment, debris clearance, search and rescue in rubble",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "police",
      "team_description": "Cordon, crowd control, EOD sweep for secondary devices, evidence preservation",
      "min_participants": 2,
      "max_participants": 8
    }
  ],
  "environmental_factors": [
    "blast_radius",
    "shrapnel_spread",
    "secondary_device_risk",
    "crowd_density",
    "open_air_debris",
    "weather_exposure"
  ],
  "adversary_behaviors": ["ied_placement", "possible_second_device", "fleeing_suspect"],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "Explosion at {venue}. Smoke, debris, casualties on the ground. Extent unknown. Crowd scattering in all directions.",
      "severity": "critical"
    },
    {
      "timing": "T+3",
      "type": "field_update",
      "template": "Reports of a second suspicious package near the perimeter. EOD team requested. Cordon expansion may be needed.",
      "severity": "critical"
    },
    {
      "timing": "T+5",
      "type": "field_update",
      "template": "Walking wounded streaming out of the area. Bystanders attempting first aid. Casualty count rising.",
      "severity": "high"
    },
    {
      "timing": "T+10",
      "type": "intel_brief",
      "template": "Emergency services en route. Traffic congestion slowing access. Self-manage until arrival.",
      "severity": "high"
    },
    {
      "timing": "T+12",
      "type": "media_report",
      "template": "Social media footage circulating. Unverified claims about perpetrator identity. Community tensions rising.",
      "severity": "critical"
    },
    {
      "timing": "T+15",
      "type": "field_update",
      "template": "Crowd tension at evacuation point. Disputes over access. Minor altercation reported.",
      "severity": "high"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "evacuate_together",
      "keywords": ["evacuate", "together", "everyone"],
      "trigger_condition": "when evacuation proceeds without demographic segregation",
      "inject_template": "Evacuation proceeds without segregation. All evacuees use same routes and assembly points."
    },
    {
      "branch_id": "segregate",
      "keywords": ["separate", "segregate", "demographic"],
      "trigger_condition": "when evacuation team receives request to segregate by demographic",
      "inject_template": "Fearful bystander requests segregation. Evacuation team must decide: comply or refuse."
    },
    {
      "branch_id": "media_statement",
      "keywords": ["statement", "misinformation", "counter"],
      "trigger_condition": "when media team submits first public statement",
      "inject_template": "Public statement submitted. Does it address misinformation? Verified facts?"
    },
    {
      "branch_id": "secondary_sweep",
      "keywords": ["sweep", "secondary", "device", "EOD"],
      "trigger_condition": "when police decide to sweep for secondary devices",
      "inject_template": "EOD sweep initiated. Area must remain cleared. Evacuation routes may need rerouting."
    }
  ],
  "compatible_settings": [
    "market",
    "street",
    "open_field",
    "mall",
    "beach",
    "hotel",
    "park",
    "worship",
    "stadium",
    "waterfront",
    "office",
    "government",
    "airport"
  ],
  "compatible_terrains": ["urban", "coastal", "rural"],
  "multi_storey": false,
  "condition_keys": [
    {
      "key": "evacuation_no_flow_control_decision",
      "meaning": "No decision matches flow/bottleneck/exit capacity keywords",
      "team": "evacuation"
    },
    {
      "key": "evacuation_flow_control_decided",
      "meaning": "evacuation_state.flow_control_decided === true",
      "team": "evacuation"
    },
    {
      "key": "evacuation_exit_bottleneck_active",
      "meaning": "exits_congested non-empty (unmanaged)",
      "team": "evacuation"
    },
    {
      "key": "evacuation_coordination_established",
      "meaning": "evacuation_state.coordination_with_triage === true",
      "team": "evacuation"
    },
    {
      "key": "triage_zone_established_as_incident_location",
      "meaning": "Decision mentions triage zone",
      "team": "triage"
    },
    {
      "key": "triage_supply_critical",
      "meaning": "triage_state.supply_level === critical",
      "team": "triage"
    },
    {
      "key": "triage_no_prioritisation_decision",
      "meaning": "No decision matches prioritisation keywords",
      "team": "triage"
    },
    {
      "key": "triage_prioritisation_decided",
      "meaning": "triage_state.prioritisation_decided === true",
      "team": "triage"
    },
    {
      "key": "media_statement_issued",
      "meaning": "media_state.first_statement_issued === true",
      "team": "media"
    },
    {
      "key": "media_no_statement_by_T12",
      "meaning": "elapsedMinutes >= 12 and no statement",
      "team": "media"
    },
    {
      "key": "media_misinformation_addressed",
      "meaning": "media_state.misinformation_addressed === true",
      "team": "media"
    },
    {
      "key": "police_no_perimeter_decision",
      "meaning": "No decision matches perimeter/cordon keywords",
      "team": "police"
    },
    {
      "key": "police_perimeter_established",
      "meaning": "police_state.perimeter_established === true",
      "team": "police"
    }
  ],
  "keyword_patterns": [
    {
      "category": "Flow control (evac)",
      "keywords": ["flow", "bottleneck", "stagger", "congestion", "egress", "exit capacity"],
      "state_key": "evacuation_state.flow_control_decided"
    },
    {
      "category": "Supply/equipment (triage)",
      "keywords": ["supply", "request", "tourniquet", "stretcher", "shortage"],
      "state_key": "triage_state.supply_request_made"
    },
    {
      "category": "Prioritisation (triage)",
      "keywords": ["prioritise", "critical first", "severity", "triage protocol"],
      "state_key": "triage_state.prioritisation_decided"
    },
    {
      "category": "Statement (media)",
      "keywords": ["statement", "press", "announce", "release"],
      "state_key": "media_state.first_statement_issued"
    },
    {
      "category": "Misinformation (media)",
      "keywords": ["debunk", "counter", "correct", "misinformation", "rumour"],
      "state_key": "media_state.misinformation_addressed"
    },
    {
      "category": "Perimeter (police)",
      "keywords": ["perimeter", "cordon", "secure", "contain", "lockdown"],
      "state_key": "police_state.perimeter_established"
    }
  ],
  "team_counter_definitions": {
    "evacuation": [
      {
        "key": "total_evacuees",
        "label": "Total Evacuees",
        "type": "number",
        "initial_value": 800,
        "behavior": "static",
        "visible_to": "all"
      },
      {
        "key": "evacuated_count",
        "label": "People Evacuated",
        "type": "number",
        "initial_value": 0,
        "behavior": "time_rate",
        "visible_to": "all",
        "config": {
          "base_rate_per_min": 50,
          "cap_key": "total_evacuees",
          "requires_flag": "flow_control_decided",
          "robustness_affects": true,
          "robustness_low_mult": 0.25,
          "robustness_high_mult": 1.25,
          "congestion_halves": true,
          "impact_sensitive": true
        }
      },
      {
        "key": "flow_control_decided",
        "label": "Flow Control Decided",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": [
            "flow",
            "bottleneck",
            "stagger",
            "egress",
            "congestion",
            "exit capacity",
            "crowd control"
          ]
        }
      },
      {
        "key": "coordination_with_triage",
        "label": "Coordination with Triage",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": { "keywords": ["coordinate", "triage"] }
      }
    ],
    "triage": [
      {
        "key": "patients_being_treated",
        "label": "Patients Being Treated",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all",
        "config": {
          "source_pool_key": "total_evacuees",
          "pool_fraction": 0.2,
          "split_fractions": { "deaths_on_site": 0.1, "handed_over_to_hospital": 0.45 }
        }
      },
      {
        "key": "patients_waiting",
        "label": "Patients Waiting",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "handed_over_to_hospital",
        "label": "Handed Over to Hospital",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "casualties",
        "label": "Casualties",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "deaths_on_site",
        "label": "Deaths on Site",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "supply_request_made",
        "label": "Supply Request Made",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": { "keywords": ["supply", "request", "tourniquet", "stretcher", "shortage"] }
      },
      {
        "key": "prioritisation_decided",
        "label": "Prioritisation Decided",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": { "keywords": ["prioritise", "critical first", "severity", "triage protocol"] }
      }
    ],
    "media": [
      {
        "key": "statements_issued",
        "label": "Statements Issued",
        "type": "number",
        "initial_value": 0,
        "behavior": "decision_increment",
        "visible_to": "all",
        "config": { "keywords": ["statement", "press", "announce", "release"] }
      },
      {
        "key": "misinformation_addressed_count",
        "label": "Misinformation Addressed",
        "type": "number",
        "initial_value": 0,
        "behavior": "decision_increment",
        "visible_to": "all",
        "config": { "keywords": ["debunk", "counter", "correct", "misinformation", "rumour"] }
      },
      {
        "key": "first_statement_issued",
        "label": "First Statement Issued",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": { "keywords": ["statement", "press", "announce", "release"] }
      },
      {
        "key": "spokesperson_designated",
        "label": "Spokesperson Designated",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": { "keywords": ["spokesperson", "one voice", "single spokesperson"] }
      }
    ],
    "fire": [
      {
        "key": "fire_contained",
        "label": "Fire Contained",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": { "keywords": ["contained", "controlled", "extinguished", "suppressed"] }
      },
      {
        "key": "debris_clearance_started",
        "label": "Debris Clearance Started",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": { "keywords": ["debris", "clearance", "rubble", "search and rescue"] }
      },
      {
        "key": "units_deployed",
        "label": "Units Deployed",
        "type": "number",
        "initial_value": 0,
        "behavior": "state_effect",
        "visible_to": "all"
      }
    ],
    "police": [
      {
        "key": "perimeter_established",
        "label": "Perimeter Established",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": { "keywords": ["perimeter", "cordon", "secure", "contain", "lockdown"] }
      },
      {
        "key": "secondary_sweep_done",
        "label": "Secondary Device Sweep Done",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": { "keywords": ["sweep", "secondary", "device", "EOD", "bomb disposal"] }
      },
      {
        "key": "armed_units",
        "label": "Armed Units",
        "type": "number",
        "initial_value": 0,
        "behavior": "state_effect",
        "visible_to": "all"
      }
    ]
  }
}
