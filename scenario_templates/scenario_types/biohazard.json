      },
      {
        "key": "units_deployed",
        "label": "Hazmat Units Deployed",
        "type": "number",
        "initial_value": 0,
        "behavior": "state_effect",
        "visible_to": "all"
      }
    ],
    "public_health": [
      {
        "key": "quarantine_established",
        "label": "Quarantine Established",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["quarantine", "isolate", "restrict", "lockdown"]
        }
      },
      {
        "key": "contact_tracing_started",
        "label": "Contact Tracing Started",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["contact", "trace", "tracking", "exposure list"]
        }
      },
      {
        "key": "advisory_issued",
        "label": "Public Advisory Issued",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["advisory", "warning", "alert", "health notice"]
        }
      },
      {
        "key": "prophylaxis_distributed",
        "label": "Prophylaxis Distributed",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": [
            "prophylaxis",
            "antidote",
            "antibiotic",
            "distribute",
            "medication",
            "vaccine"
          ]
        }
      },
      {
        "key": "population_exposed",
        "label": "Est. Population Exposed",
        "type": "number",
        "initial_value": 200,
        "behavior": "static",
        "visible_to": "all"
      },
      {
        "key": "confirmed_cases",
        "label": "Confirmed Symptomatic Cases",
        "type": "number",
        "initial_value": 0,
        "behavior": "state_effect",
        "visible_to": "all"
      }
    ],
    "triage": [
      {
        "key": "total_patients",
        "label": "Total Patients",
        "type": "number",
        "initial_value": 80,
        "behavior": "static",
        "visible_to": "all"
      },
      {
        "key": "triage_processed",
        "label": "Patients Processed",
        "type": "number",
        "initial_value": 0,
        "behavior": "time_rate",
        "visible_to": "trainer_only",
        "config": {
          "base_rate_per_min": 6,
          "cap_key": "total_patients",
          "robustness_affects": true,
          "robustness_low_mult": 0.5,
          "robustness_high_mult": 1.25,
          "impact_sensitive": true,
          "rate_modifier_key": "treatment_rate_modifier"
        }
      },
      {
        "key": "treatment_rate_modifier",
        "label": "Treatment Rate Modifier",
        "type": "number",
        "initial_value": 1,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "patients_being_treated",
        "label": "Patients Being Treated",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all",
        "config": {
          "source_pool_key": "total_patients",
          "rate_key": "triage_processed",
          "split_fractions": {
            "deaths_on_site": 0.08,
            "handed_over_to_hospital": 0.5
          },
          "split_fractions_low": {
            "deaths_on_site": 0.18,
            "handed_over_to_hospital": 0.25
          },
          "split_fractions_high": {
            "deaths_on_site": 0.03,
            "handed_over_to_hospital": 0.65
          }
        }
      },
      {
        "key": "patients_waiting",
        "label": "Patients Waiting",
        "type": "number",
        "initial_value": 80,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "handed_over_to_hospital",
        "label": "Handed Over to Hospital",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "deaths_on_site",
        "label": "Deaths on Site",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "patients_decontaminated",
        "label": "Patients Decontaminated",
        "type": "number",
        "initial_value": 0,
        "behavior": "time_rate",
        "visible_to": "all",
        "config": {
          "base_rate_per_min": 8,
          "robustness_affects": true,
          "requires_flag": "decontamination_active"
        }
      },
      {
        "key": "decontamination_active",
        "label": "Decontamination Active",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["decontamination", "decon", "wash", "rinse"]
        }
      }
