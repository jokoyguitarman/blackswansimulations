{
  "id": "biohazard",
  "display_name": "Biological attack / hazardous agent release",
  "category": "terrorism",
  "required_teams": [
    {
      "team_name": "Evacuation",
      "team_description": "Controlled evacuation from contaminated zones, shelter-in-place coordination, perimeter cordon, crowd flow management",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Fire Safety",
      "team_description": "BSL containment, biological agent identification, decontamination stations, hot/warm/cold zone management, hazmat response",
      "min_participants": 2,
      "max_participants": 10
    },
    {
      "team_name": "Medical Triage",
      "team_description": "Mass casualty triage, symptom-based prioritization, quarantine enforcement, contact tracing, hospital surge coordination",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Media & Communications",
      "team_description": "Public health advisory communications, counter misinformation, government liaison, press management",
      "min_participants": 2,
      "max_participants": 6
    }
  ],
  "environmental_factors": [
    "agent_type",
    "dispersal_method",
    "incubation_period",
    "wind_direction",
    "enclosed_vs_open",
    "population_density",
    "ventilation_system"
  ],
  "has_adversary": true,
  "adversary_behaviors": [
    "delayed_symptom_exploitation",
    "multiple_release_points",
    "false_claims_of_agent_type",
    "secondary_release",
    "fleeing_after_release"
  ],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "Unknown substance released at {venue}. Multiple people collapsing with acute symptoms — respiratory distress, skin irritation, nausea. Source and agent unidentified.",
      "severity": "critical"
    },
    {
      "timing": "T+5",
      "type": "field_update",
      "template": "Agent suspected biological. Hospitals reporting surge of symptomatic patients. Dispersal pattern suggests deliberate release. Exposure radius unknown.",
      "severity": "critical"
    },
    {
      "timing": "T+10",
      "type": "intel_brief",
      "template": "Lab results indicate biological agent. Exact pathogen identification pending. Exposure window unknown. Contact tracing decision needed urgently.",
      "severity": "high"
    },
    {
      "timing": "T+15",
      "type": "media_report",
      "template": "Social media panic spreading. Misinformation about airborne contagion. Public demanding mass testing. Unverified reports of symptoms in adjacent areas.",
      "severity": "high"
    },
    {
      "timing": "T+20",
      "type": "field_update",
      "template": "Second release point suspected. HAZMAT and public health resources stretched. Quarantine compliance dropping. Hospital capacity nearing limit.",
      "severity": "critical"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "quarantine_vs_evacuate",
      "keywords": ["quarantine", "evacuate", "isolate", "contain", "lockdown"],
      "trigger_condition": "when command decides to quarantine the contaminated area or evacuate (risking spread)",
      "inject_template": "Quarantine risks trapping exposed civilians. Evacuation risks spreading the agent. Which approach?"
    },
    {
      "branch_id": "agent_disclosure",
      "keywords": ["disclose", "announce agent", "identify", "public", "name the agent"],
      "trigger_condition": "when decision is made on whether and how to publicly disclose the identified agent",
      "inject_template": "Agent identified. Disclosing may cause panic but enables self-triage. Withholding risks loss of public trust."
    },
    {
      "branch_id": "mass_prophylaxis",
      "keywords": ["prophylaxis", "antidote", "antibiotic", "distribute", "medication", "vaccine"],
      "trigger_condition": "when decision is made to initiate mass prophylaxis or antidote distribution",
      "inject_template": "Mass prophylaxis authorised. Supply limited. Distribution point selection and priority order needed."
    },
    {
      "branch_id": "media_statement",
      "keywords": ["statement", "press", "announce", "release"],
      "trigger_condition": "when media team issues public statement",
      "inject_template": "Public statement issued. Does it provide clear health guidance without causing panic?"
    }
  ],
  "compatible_settings": [
    "subway",
    "airport",
    "mall",
    "stadium",
    "government",
    "office",
    "hospital",
    "industrial"
  ],
  "compatible_terrains": ["urban", "coastal", "rural"],
  "multi_storey": false,
  "condition_keys": [
    {
      "key": "quarantine_not_established",
      "meaning": "No quarantine or containment decision made by expected time",
      "team": "public_health"
    },
    {
      "key": "agent_not_identified_by_T15",
      "meaning": "elapsedMinutes >= 15 and fire_hazmat has not identified the agent",
      "team": "fire_hazmat"
    },
    {
      "key": "public_advisory_not_issued",
      "meaning": "No public health advisory decision made",
      "team": "public_health"
    },
    {
      "key": "media_no_statement_by_T12",
      "meaning": "elapsedMinutes >= 12 and no statement",
      "team": "media"
    }
  ],
  "keyword_patterns": [
    {
      "category": "Containment (fire_hazmat)",
      "keywords": ["contain", "isolate", "seal", "zone", "cordon", "decon"],
      "state_key": "fire_hazmat_state.containment_started"
    },
    {
      "category": "Quarantine (public_health)",
      "keywords": ["quarantine", "isolate", "restrict", "lockdown", "contain"],
      "state_key": "public_health_state.quarantine_established"
    },
    {
      "category": "Advisory (public_health)",
      "keywords": ["advisory", "warning", "alert", "health notice"],
      "state_key": "public_health_state.advisory_issued"
    },
    {
      "category": "Statement (media)",
      "keywords": ["statement", "press", "announce", "release"],
      "state_key": "media_state.first_statement_issued"
    }
  ],
  "team_counter_definitions": {
    "fire_hazmat": [
      {
        "key": "agent_identified",
        "label": "Agent Identified",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["identified", "agent", "biological", "pathogen", "detected"]
        }
      },
      {
        "key": "containment_started",
        "label": "Containment Started",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["contain", "isolate", "seal", "zone"]
        }
      },
      {
        "key": "hot_zone_established",
        "label": "Hot Zone Established",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["hot zone", "exclusion", "hazard zone", "cordon"]
        }
      },
      {
        "key": "decon_active",
        "label": "Decontamination Active",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["decontamination", "decon", "wash"]
        }
      },
      {
        "key": "samples_collected",
        "label": "Samples Collected",
        "type": "number",
        "initial_value": 0,
        "behavior": "decision_increment",
        "visible_to": "all",
        "config": {
          "keywords": ["sample", "collect", "swab", "culture", "lab"]
