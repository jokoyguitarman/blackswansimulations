{
  "id": "suicide_bombing",
  "display_name": "Suicide bombing (person-borne IED)",
  "category": "terrorism",
  "required_teams": [
    {
      "team_name": "evacuation",
      "team_description": "Immediate crowd evacuation from blast zone, manage panic and stampede risk",
      "min_participants": 2,
      "max_participants": 10
    },
    {
      "team_name": "triage",
      "team_description": "Mass casualty triage, blast/shrapnel injuries, coordinate ambulance handover",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "police",
      "team_description": "Cordon, identify possible accomplices, secondary threat sweep, evidence preservation",
      "min_participants": 2,
      "max_participants": 10
    },
    {
      "team_name": "media",
      "team_description": "Public communication, counter misinformation, manage community tensions",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "fire",
      "team_description": "Fire suppression, debris clearance, search and rescue",
      "min_participants": 2,
      "max_participants": 8
    }
  ],
  "environmental_factors": [
    "blast_radius",
    "shrapnel_pattern",
    "crowd_density_at_detonation",
    "secondary_attacker_risk",
    "structural_damage",
    "panic_stampede_risk"
  ],
  "adversary_behaviors": ["crowd_targeting", "secondary_attacker", "accomplice_surveillance"],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "Explosion at {venue}. Suicide bomber confirmed or suspected. Mass casualties. Panic and stampede risk.",
      "severity": "critical"
    },
    {
      "timing": "T+3",
      "type": "intel_brief",
      "template": "Intelligence suggests possible second attacker in the crowd. Immediate sweep needed. CCTV review underway.",
      "severity": "critical"
    },
    {
      "timing": "T+8",
      "type": "field_update",
      "template": "Casualty count rising. Walking wounded overwhelming triage. Ambulance access blocked by crowd.",
      "severity": "high"
    },
    {
      "timing": "T+12",
      "type": "media_report",
      "template": "Graphic footage circulating online. Community blame narratives emerging. Hate incidents reported nearby.",
      "severity": "critical"
    },
    {
      "timing": "T+15",
      "type": "field_update",
      "template": "Suspicious individual spotted near cordon. Police must assess: genuine threat or panicked bystander?",
      "severity": "high"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "evacuate_together",
      "keywords": ["evacuate", "together", "everyone"],
      "trigger_condition": "when evacuation proceeds without demographic segregation",
      "inject_template": "Evacuation proceeds without segregation. All evacuees use same routes."
    },
    {
      "branch_id": "secondary_sweep",
      "keywords": ["sweep", "secondary", "attacker", "accomplice"],
      "trigger_condition": "when police initiate secondary threat sweep",
      "inject_template": "Secondary sweep initiated. Crowd must be held at distance. Routes may need rerouting."
    },
    {
      "branch_id": "media_statement",
      "keywords": ["statement", "press", "announce"],
      "trigger_condition": "when media team issues first statement",
      "inject_template": "Public statement issued. Does it address community tensions? Verified information only?"
    }
  ],
  "compatible_settings": [
    "market",
    "street",
    "mall",
    "subway",
    "train",
    "open_field",
    "worship",
    "stadium",
    "airport",
    "park"
  ],
  "compatible_terrains": ["urban", "coastal", "rural"],
  "multi_storey": false,
  "condition_keys": [
    {
      "key": "evacuation_no_flow_control_decision",
      "meaning": "No decision matches flow/crowd control keywords",
      "team": "evacuation"
    },
    {
      "key": "evacuation_flow_control_decided",
      "meaning": "evacuation_state.flow_control_decided === true",
      "team": "evacuation"
    },
    {
      "key": "triage_no_prioritisation_decision",
      "meaning": "No decision matches prioritisation keywords",
      "team": "triage"
    },
    {
      "key": "police_no_perimeter_decision",
      "meaning": "No decision matches perimeter/cordon keywords",
      "team": "police"
    },
    {
      "key": "media_no_statement_by_T12",
      "meaning": "elapsedMinutes >= 12 and no statement",
      "team": "media"
    }
  ],
  "keyword_patterns": [
    {
      "category": "Flow control (evac)",
      "keywords": ["flow", "bottleneck", "stagger", "congestion", "crowd control", "stampede"],
      "state_key": "evacuation_state.flow_control_decided"
    },
    {
      "category": "Perimeter (police)",
      "keywords": ["perimeter", "cordon", "secure", "contain", "lockdown"],
      "state_key": "police_state.perimeter_established"
    },
    {
      "category": "Statement (media)",
      "keywords": ["statement", "press", "announce", "release"],
      "state_key": "media_state.first_statement_issued"
    },
    {
      "category": "Misinformation (media)",
      "keywords": ["debunk", "counter", "correct", "misinformation", "rumour"],
      "state_key": "media_state.misinformation_addressed"
    }
  ],
  "team_counter_definitions": {
    "evacuation": [
      {
        "key": "total_evacuees",
        "label": "Total Evacuees",
        "type": "number",
        "initial_value": 600,
        "behavior": "static",
        "visible_to": "all"
      },
      {
        "key": "evacuated_count",
        "label": "People Evacuated",
        "type": "number",
        "initial_value": 0,
        "behavior": "time_rate",
        "visible_to": "all",
        "config": {
          "base_rate_per_min": 50,
          "cap_key": "total_evacuees",
          "requires_flag": "flow_control_decided",
          "robustness_affects": true,
          "congestion_halves": true,
          "impact_sensitive": true
        }
      },
      {
        "key": "flow_control_decided",
        "label": "Flow Control Decided",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": { "keywords": ["flow", "crowd control", "stagger", "stampede", "egress"] }
      },
      {
        "key": "coordination_with_triage",
        "label": "Coordination with Triage",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": { "keywords": ["coordinate", "triage"] }
      }
    ],
    "triage": [
      {
        "key": "patients_being_treated",
        "label": "Patients Being Treated",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all",
        "config": {
          "source_pool_key": "total_evacuees",
          "pool_fraction": 0.3,
          "split_fractions": { "deaths_on_site": 0.15, "handed_over_to_hospital": 0.4 }
        }
      },
      {
        "key": "patients_waiting",
        "label": "Patients Waiting",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "handed_over_to_hospital",
        "label": "Handed Over to Hospital",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "casualties",
        "label": "Casualties",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "deaths_on_site",
        "label": "Deaths on Site",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "prioritisation_decided",
        "label": "Prioritisation Decided",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": { "keywords": ["prioritise", "critical first", "severity", "triage protocol"] }
      }
    ],
    "police": [
      {
        "key": "perimeter_established",
        "label": "Perimeter Established",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": { "keywords": ["perimeter", "cordon", "secure", "contain"] }
      },
      {
        "key": "secondary_sweep_done",
        "label": "Secondary Threat Sweep Done",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": { "keywords": ["sweep", "secondary", "accomplice", "check"] }
      },
      {
        "key": "armed_units",
        "label": "Armed Units",
        "type": "number",
        "initial_value": 0,
        "behavior": "state_effect",
        "visible_to": "all"
      }
    ],
    "media": [
      {
        "key": "statements_issued",
        "label": "Statements Issued",
        "type": "number",
        "initial_value": 0,
        "behavior": "decision_increment",
        "visible_to": "all",
        "config": { "keywords": ["statement", "press", "announce", "release"] }
      },
      {
        "key": "misinformation_addressed_count",
        "label": "Misinformation Addressed",
        "type": "number",
        "initial_value": 0,
        "behavior": "decision_increment",
        "visible_to": "all",
        "config": { "keywords": ["debunk", "counter", "correct", "misinformation", "rumour"] }
      },
      {
        "key": "first_statement_issued",
        "label": "First Statement Issued",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": { "keywords": ["statement", "press", "announce", "release"] }
      }
    ],
    "fire": [
      {
        "key": "fire_contained",
        "label": "Fire Contained",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": { "keywords": ["contained", "controlled", "extinguished"] }
      },
      {
        "key": "debris_clearance_started",
        "label": "Debris Clearance Started",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": { "keywords": ["debris", "clearance", "rubble", "search and rescue"] }
      },
      {
        "key": "units_deployed",
        "label": "Units Deployed",
        "type": "number",
        "initial_value": 0,
        "behavior": "state_effect",
        "visible_to": "all"
      }
    ]
  }
}
