{
  "id": "suicide_bombing",
  "display_name": "Suicide bombing (person-borne IED)",
  "category": "terrorism",
  "required_teams": [
    {
      "team_name": "Evacuation",
      "team_description": "Immediate crowd evacuation from blast zone, stampede prevention, assembly point management, perimeter control",
      "min_participants": 2,
      "max_participants": 10
    },
    {
      "team_name": "Fire Safety",
      "team_description": "Fire suppression, debris clearance, search and rescue in blast zone",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Medical Triage",
      "team_description": "Mass casualty triage for blast and shrapnel injuries, stabilization, ambulance coordination",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Media & Communications",
      "team_description": "Public communication, counter-misinformation, community tensions management, press coordination",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "Bomb Squad / EOD",
      "team_description": "Secondary device sweep, render safe procedures, IED forensics, blast cordon establishment",
      "min_participants": 2,
      "max_participants": 6
    }
  ],
  "environmental_factors": [
    "blast_radius",
    "shrapnel_pattern",
    "crowd_density_at_detonation",
    "secondary_attacker_risk",
    "structural_damage",
    "panic_stampede_risk"
  ],
  "has_adversary": true,
  "adversary_behaviors": [
    "crowd_targeting",
    "secondary_attacker",
    "accomplice_surveillance",
    "accomplice_fleeing"
  ],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "Explosion at {venue}. Suicide bomber confirmed or suspected. Mass casualties. Panic and stampede risk.",
      "severity": "critical"
    },
    {
      "timing": "T+3",
      "type": "intel_brief",
      "template": "Intelligence suggests possible second attacker in the crowd. Immediate sweep needed. CCTV review underway.",
      "severity": "critical"
    },
    {
      "timing": "T+8",
      "type": "field_update",
      "template": "Casualty count rising. Walking wounded overwhelming triage. Ambulance access blocked by crowd.",
      "severity": "high"
    },
    {
      "timing": "T+12",
      "type": "media_report",
      "template": "Graphic footage circulating online. Community blame narratives emerging. Hate incidents reported nearby.",
      "severity": "critical"
    },
    {
      "timing": "T+15",
      "type": "field_update",
      "template": "Suspicious individual spotted near cordon. Police must assess: genuine threat or panicked bystander?",
      "severity": "high"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "evacuate_together",
      "keywords": ["evacuate", "together", "everyone"],
      "trigger_condition": "when evacuation proceeds without demographic segregation",
      "inject_template": "Evacuation proceeds without segregation. All evacuees use same routes."
    },
    {
      "branch_id": "secondary_sweep",
      "keywords": ["sweep", "secondary", "attacker", "accomplice"],
      "trigger_condition": "when police initiate secondary threat sweep",
      "inject_template": "Secondary sweep initiated. Crowd must be held at distance. Routes may need rerouting."
    },
    {
      "branch_id": "media_statement",
      "keywords": ["statement", "press", "announce"],
      "trigger_condition": "when media team issues first statement",
      "inject_template": "Public statement issued. Does it address community tensions? Verified information only?"
    }
  ],
  "compatible_settings": [
    "market",
    "street",
    "mall",
    "subway",
    "train",
    "open_field",
    "worship",
    "stadium",
    "airport",
    "park"
  ],
  "compatible_terrains": ["urban", "coastal", "rural"],
  "multi_storey": false,
  "condition_keys": [
    {
      "key": "evacuation_no_flow_control_decision",
      "meaning": "No decision matches flow/crowd control keywords",
      "team": "evacuation"
    },
    {
      "key": "evacuation_flow_control_decided",
      "meaning": "evacuation_state.flow_control_decided === true",
      "team": "evacuation"
    },
    {
      "key": "triage_no_prioritisation_decision",
      "meaning": "No decision matches prioritisation keywords",
      "team": "triage"
    },
    {
      "key": "police_no_perimeter_decision",
      "meaning": "No decision matches perimeter/cordon keywords",
      "team": "police"
    },
    {
      "key": "media_no_statement_by_T12",
      "meaning": "elapsedMinutes >= 12 and no statement",
      "team": "media"
    }
  ],
  "keyword_patterns": [
    {
      "category": "Flow control (evac)",
      "keywords": ["flow", "bottleneck", "stagger", "congestion", "crowd control", "stampede"],
      "state_key": "evacuation_state.flow_control_decided"
    },
    {
      "category": "Perimeter (police)",
      "keywords": ["perimeter", "cordon", "secure", "contain", "lockdown"],
      "state_key": "police_state.perimeter_established"
    },
    {
      "category": "Statement (media)",
      "keywords": ["statement", "press", "announce", "release"],
      "state_key": "media_state.first_statement_issued"
    },
    {
      "category": "Misinformation (media)",
      "keywords": ["debunk", "counter", "correct", "misinformation", "rumour"],
      "state_key": "media_state.misinformation_addressed"
    }
  ],
  "team_counter_definitions": {
    "evacuation": [
      {
        "key": "total_evacuees",
        "label": "Total Evacuees",
        "type": "number",
        "initial_value": 600,
        "behavior": "static",
        "visible_to": "all"
      },
      {
        "key": "evacuated_count",
        "label": "People Evacuated",
        "type": "number",
        "initial_value": 0,
        "behavior": "time_rate",
        "visible_to": "all",
        "config": {
          "base_rate_per_min": 50,
          "cap_key": "total_evacuees",
          "requires_flag": "flow_control_decided",
          "robustness_affects": true,
          "congestion_halves": true,
          "impact_sensitive": true,
          "rate_modifier_key": "evac_rate_modifier",
          "marshal_boost_key": "marshals_deployed",
          "marshal_boost_mult": 1.15
        }
      },
      {
        "key": "evac_rate_modifier",
        "label": "Evacuation Rate Modifier",
        "type": "number",
        "initial_value": 1,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "flow_control_decided",
        "label": "Flow Control Decided",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["flow", "crowd control", "stagger", "stampede", "egress"]
        }
      },
      {
        "key": "marshals_deployed",
        "label": "Marshals / Stewards Deployed",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["marshal", "steward", "guide", "warden", "usher", "crowd marshal"]
        }
      },
      {
        "key": "coordination_with_triage",
        "label": "Coordination with Triage",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": {
          "keywords": ["coordinate", "triage"]
        }
      }
    ],
    "triage": [
      {
        "key": "total_patients",
        "label": "Total Patients",
        "type": "number",
        "initial_value": 160,
        "behavior": "static",
        "visible_to": "all"
      },
      {
        "key": "triage_processed",
        "label": "Patients Processed",
        "type": "number",
        "initial_value": 0,
        "behavior": "time_rate",
        "visible_to": "trainer_only",
        "config": {
          "base_rate_per_min": 8,
          "cap_key": "total_patients",
          "robustness_affects": true,
          "robustness_low_mult": 0.5,
          "robustness_high_mult": 1.25,
          "impact_sensitive": true,
          "rate_modifier_key": "treatment_rate_modifier"
        }
      },
      {
        "key": "treatment_rate_modifier",
        "label": "Treatment Rate Modifier",
        "type": "number",
        "initial_value": 1,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "patients_being_treated",
        "label": "Patients Being Treated",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all",
        "config": {
          "source_pool_key": "total_patients",
          "rate_key": "triage_processed",
          "split_fractions": {
            "deaths_on_site": 0.12,
            "handed_over_to_hospital": 0.4
          },
          "split_fractions_low": {
            "deaths_on_site": 0.25,
            "handed_over_to_hospital": 0.2
          },
          "split_fractions_high": {
            "deaths_on_site": 0.05,
            "handed_over_to_hospital": 0.6
          }
        }
      },
      {
        "key": "patients_waiting",
