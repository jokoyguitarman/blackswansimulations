{
  "id": "hostage_siege",
  "display_name": "Hostage siege / barricade",
  "category": "terrorism",
  "required_teams": [
    {
      "team_name": "Evacuation",
      "team_description": "Perimeter establishment, area lockdown, crowd management, bystander evacuation",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Medical Triage",
      "team_description": "Standby medical support, hostage medical assessment, stress casualty support, casualty stabilization",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "Media & Communications",
      "team_description": "Media blackout coordination, family liaison, public communication, press management",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "Pursuit & Investigation",
      "team_description": "Tactical response, hostage negotiation, real-time surveillance, building intel, entry planning, suspect profiling",
      "min_participants": 2,
      "max_participants": 10,
      "is_investigative": true
    }
  ],
  "environmental_factors": [
    "building_entry_points",
    "hostage_count",
    "perpetrator_demands",
    "siege_duration",
    "supplies_status"
  ],
  "has_adversary": true,
  "adversary_behaviors": [
    "demand_escalation",
    "hostage_execution_threat",
    "media_exploitation",
    "fortification",
    "barricade"
  ],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "Armed individuals have seized {venue}. Hostages taken. Building secured by perpetrators. Demands expected.",
      "severity": "critical"
    },
    {
      "timing": "T+10",
      "type": "intel_brief",
      "template": "Demands received: political/financial. Deadline set. Hostage count estimated but unconfirmed.",
      "severity": "critical"
    },
    {
      "timing": "T+20",
      "type": "field_update",
      "template": "Perpetrators growing agitated. Hostage released as show of intent — or threat of execution if demands not met.",
      "severity": "critical"
    },
    {
      "timing": "T+30",
      "type": "media_report",
      "template": "Media converging on scene. Live broadcasts showing tactical positions. OPSEC concern.",
      "severity": "high"
    },
    {
      "timing": "T+40",
      "type": "field_update",
      "template": "Deadline approaching. Negotiations stalling. Tactical intervention decision point.",
      "severity": "critical"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "negotiate",
      "keywords": ["negotiate", "talk", "demand", "extend deadline"],
      "trigger_condition": "when negotiation team establishes active dialogue",
      "inject_template": "Dialogue established. Perpetrators presenting demands. Time-buying strategy needed."
    },
    {
      "branch_id": "tactical_entry",
      "keywords": ["breach", "assault", "tactical", "storm", "entry"],
      "trigger_condition": "when tactical intervention is authorised",
      "inject_template": "Tactical entry authorised. Risk to hostages assessed. Entry team moving into position."
    },
    {
      "branch_id": "media_blackout",
      "keywords": ["blackout", "media", "restrict", "no broadcast"],
      "trigger_condition": "when media blackout is requested",
      "inject_template": "Media blackout requested. Some outlets comply, others refuse. Social media continues."
    }
  ],
  "compatible_settings": ["office", "government", "hotel", "worship", "campus", "hospital", "mall"],
  "compatible_terrains": ["urban"],
  "multi_storey": true,
  "condition_keys": [
    {
      "key": "police_no_perimeter_decision",
      "meaning": "No perimeter decision made",
      "team": "police"
    },
    {
      "key": "negotiation_not_initiated",
      "meaning": "negotiation_state.contact_established !== true",
      "team": "negotiation"
    },
    {
      "key": "media_no_statement_by_T12",
      "meaning": "elapsedMinutes >= 12 and no statement",
      "team": "media"
    }
  ],
  "keyword_patterns": [
    {
      "category": "Perimeter (police)",
      "keywords": ["perimeter", "cordon", "secure", "contain", "sniper"],
      "state_key": "police_state.perimeter_established"
    },
    {
      "category": "Contact (negotiation)",
      "keywords": ["contact", "negotiate", "talk", "communicate", "demand"],
      "state_key": "negotiation_state.contact_established"
    },
    {
      "category": "Statement (media)",
      "keywords": ["statement", "press", "announce", "release"],
      "state_key": "media_state.first_statement_issued"
    }
  ],
