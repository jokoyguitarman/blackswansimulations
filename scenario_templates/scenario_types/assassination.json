        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["sweep", "secondary", "device", "bomb", "search"]
        }
      }
    ],
    "intelligence": [
      {
        "key": "threat_assessment_complete",
        "label": "Threat Assessment Complete",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["threat", "assessment", "profile", "intelligence", "analysis"]
        }
      },
      {
        "key": "suspect_identified",
        "label": "Suspect(s) Identified",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["identified", "suspect", "perpetrator", "description"]
        }
      },
      {
        "key": "surveillance_deployed",
        "label": "Surveillance Deployed",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["surveillance", "drone", "cctv", "monitor", "observe"]
        }
      },
      {
        "key": "intel_reports_issued",
        "label": "Intelligence Reports Issued",
        "type": "number",
        "initial_value": 0,
        "behavior": "decision_increment",
        "visible_to": "trainer_only",
        "config": {
          "keywords": ["report", "brief", "intel", "update", "sitrep"]
        }
      }
    ]
  }
}
