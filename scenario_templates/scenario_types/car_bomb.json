{
  "id": "car_bomb",
  "display_name": "Car bomb / suicide bomber",
  "category": "terrorism",
  "required_teams": [
    {
      "team_name": "Evacuation",
      "team_description": "Blast zone evacuation, crowd flow management, perimeter cordon, assembly points, access control",
      "min_participants": 2,
      "max_participants": 10
    },
    {
      "team_name": "Hazards / Fire / Rescue",
      "team_description": "Vehicle fire containment, structural assessment, debris clearance, search and rescue",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Medical Triage",
      "team_description": "Blast and burn injury triage, casualty prioritization, ambulance coordination, casualty stabilization",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Media & Communications",
      "team_description": "Public communication, counter misinformation, press management, community liaison",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "Bomb Squad / EOD",
      "team_description": "VBIED assessment, secondary device sweep, render safe procedures, controlled detonation, forensic analysis",
      "min_participants": 2,
      "max_participants": 6
    }
  ],
  "environmental_factors": [
    "blast_radius",
    "secondary_collapse",
    "vehicle_access",
    "secondary_fire_risk"
  ],
  "has_adversary": true,
  "adversary_behaviors": [
    "vehicle_approach",
    "pedestrian_approach",
    "possible_second_attacker",
    "fleeing_on_foot",
    "remote_detonation_operator"
  ],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "Explosion at {venue}. Smoke, debris, casualties. Extent unknown. Blast radius unclear.",
      "severity": "critical"
    },
    {
      "timing": "T+5",
      "type": "field_update",
      "template": "Conflicting reports. Possible second device. Suspect may have fled. Vehicle or pedestrian approach?",
      "severity": "high"
    },
    {
      "timing": "T+10",
      "type": "intel_brief",
      "template": "Emergency services delayed. Traffic congestion. Self-manage extended. Ambulance ETA unclear.",
      "severity": "high"
    },
    {
      "timing": "T+12",
      "type": "field_update",
      "template": "Secondary fire risk. Structural damage to nearby buildings. Cordon expansion may be needed.",
      "severity": "high"
    },
    {
      "timing": "T+15",
      "type": "media_report",
      "template": "Viral misinformation: false claims about perpetrator identity. Community tensions rising.",
      "severity": "critical"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "evacuate_together",
      "keywords": ["evacuate", "together", "everyone"],
      "trigger_condition": "when evacuation proceeds without demographic segregation",
      "inject_template": "Evacuation proceeds without segregation. All evacuees use same routes and assembly points."
    },
    {
      "branch_id": "segregate",
      "keywords": ["separate", "segregate", "demographic"],
      "trigger_condition": "when evacuation team receives request to segregate by demographic",
      "inject_template": "Fearful resident requests segregation. Evacuation team must decide: comply or refuse."
    },
    {
      "branch_id": "media_statement",
      "keywords": ["statement", "misinformation", "counter"],
      "trigger_condition": "when media team submits first public statement",
      "inject_template": "Public statement submitted. Does it address misinformation? Verified facts?"
    }
  ],
  "compatible_settings": [
    "mall",
    "open_field",
    "beach",
    "hotel",
    "market",
    "street",
    "office",
    "government",
    "worship",
    "stadium",
    "airport",
    "waterfront"
  ],
  "compatible_terrains": ["urban", "coastal", "rural", "desert"],
  "condition_keys": [
    {
      "key": "evacuation_no_flow_control_decision",
      "meaning": "No decision matches flow/bottleneck/exit capacity keywords",
      "team": "evacuation"
    },
    {
      "key": "evacuation_flow_control_decided",
      "meaning": "evacuation_state.flow_control_decided === true",
      "team": "evacuation"
    },
    {
      "key": "evacuation_exit_bottleneck_active",
      "meaning": "exits_congested non-empty (unmanaged)",
      "team": "evacuation"
    },
    {
      "key": "evacuation_coordination_established",
      "meaning": "evacuation_state.coordination_with_triage === true",
      "team": "evacuation"
    },
    {
      "key": "triage_zone_established_as_incident_location",
      "meaning": "Decision mentions triage zone",
      "team": "triage"
    },
    {
      "key": "triage_supply_critical",
      "meaning": "triage_state.supply_level === critical",
      "team": "triage"
    },
    {
      "key": "triage_surge_active",
      "meaning": "triage_state.surge_active === true",
      "team": "triage"
    },
    {
      "key": "triage_no_prioritisation_decision",
      "meaning": "No decision matches prioritisation keywords",
      "team": "triage"
    },
    {
      "key": "triage_prioritisation_decided",
      "meaning": "triage_state.prioritisation_decided === true",
      "team": "triage"
    },
    {
      "key": "media_statement_issued",
      "meaning": "media_state.first_statement_issued === true",
      "team": "media"
    },
    {
      "key": "media_no_statement_by_T12",
      "meaning": "elapsedMinutes >= 12 and no statement",
      "team": "media"
    },
    {
      "key": "media_misinformation_addressed",
      "meaning": "media_state.misinformation_addressed === true",
      "team": "media"
    }
  ],
  "keyword_patterns": [
    {
      "category": "Flow control (evac)",
      "keywords": ["flow", "bottleneck", "stagger", "congestion", "egress", "exit capacity"],
      "state_key": "evacuation_state.flow_control_decided"
    },
    {
      "category": "Supply/equipment (triage)",
      "keywords": ["supply", "request", "tourniquet", "stretcher", "shortage"],
      "state_key": "triage_state.supply_request_made"
    },
    {
      "category": "Prioritisation (triage)",
      "keywords": ["prioritise", "critical first", "severity", "triage protocol"],
      "state_key": "triage_state.prioritisation_decided"
    },
    {
      "category": "Statement (media)",
      "keywords": ["statement", "press", "announce", "release"],
      "state_key": "media_state.first_statement_issued"
    },
    {
      "category": "Misinformation (media)",
      "keywords": ["debunk", "counter", "correct", "misinformation", "rumour"],
      "state_key": "media_state.misinformation_addressed"
    }
  ],
