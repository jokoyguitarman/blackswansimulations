{
  "id": "knife_attack",
  "display_name": "Knife attack",
  "category": "terrorism",
  "required_teams": [
    {
      "team_name": "evacuation",
      "team_description": "Evacuate participants, manage choke points, prevent trampling",
      "min_participants": 2,
      "max_participants": 10
    },
    {
      "team_name": "triage",
      "team_description": "Establish triage, prioritize stabbing injuries",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "media",
      "team_description": "Manage media, counter speculation",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "transit_security",
      "team_description": "Transit security, coordinate station/platform evacuation",
      "min_participants": 2,
      "max_participants": 6
    }
  ],
  "environmental_factors": [
    "choke_points",
    "enclosed_corridors",
    "platform_edges",
    "escalator_safety"
  ],
  "adversary_behaviors": ["close_quarters", "blend_in_crowd", "multiple_entry_exit_points"],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "Stabbing reported at {venue}. Attacker may still be on site. Choke points at escalators and platforms.",
      "severity": "critical"
    },
    {
      "timing": "T+5",
      "type": "field_update",
      "template": "Conflicting witness reports. Attacker description varies. Multiple exits; attacker could move between them.",
      "severity": "high"
    },
    {
      "timing": "T+8",
      "type": "intel_brief",
      "template": "Attacker seen moving between platforms. Evacuation routes at risk. Transit security coordinating.",
      "severity": "high"
    },
    {
      "timing": "T+10",
      "type": "citizen_call",
      "template": "Injured person at platform edge. Trampling risk. Triage and evacuation coordination needed.",
      "severity": "high"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "stop_trains",
      "keywords": ["stop", "trains", "halt", "service"],
      "trigger_condition": "when transit security or coordination decides to halt train service",
      "inject_template": "Stop all trains? Prevents attacker escape but may strand passengers. Continue service? Risk of attacker moving."
    },
    {
      "branch_id": "platform_order",
      "keywords": ["platform", "evacuate", "order"],
      "trigger_condition": "when evacuation team decides platform evacuation order",
      "inject_template": "Multiple platforms. Which to evacuate first? Attacker location unknown."
    }
  ],
  "compatible_settings": [
    "subway",
    "mall",
    "street",
    "market",
    "train",
    "park",
    "waterfront",
    "worship"
  ],
  "compatible_terrains": ["urban"],
  "team_counter_definitions": {
    "evacuation": [
      {
        "key": "total_evacuees",
        "label": "Total Evacuees",
        "type": "number",
        "initial_value": 500,
        "behavior": "static",
        "visible_to": "all"
      },
      {
        "key": "evacuated_count",
        "label": "People Evacuated",
        "type": "number",
        "initial_value": 0,
        "behavior": "time_rate",
        "visible_to": "all",
        "config": {
          "base_rate_per_min": 35,
          "cap_key": "total_evacuees",
          "requires_flag": "flow_control_decided",
          "robustness_affects": true,
          "congestion_halves": true,
          "impact_sensitive": true,
          "rate_modifier_key": "evac_rate_modifier",
          "marshal_boost_key": "marshals_deployed",
          "marshal_boost_mult": 1.15
        }
      },
      {
        "key": "evac_rate_modifier",
        "label": "Evacuation Rate Modifier",
        "type": "number",
        "initial_value": 1,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "flow_control_decided",
        "label": "Flow Control Decided",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["flow", "bottleneck", "stagger", "egress", "congestion", "choke point"]
        }
      },
      {
        "key": "marshals_deployed",
        "label": "Marshals / Stewards Deployed",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["marshal", "steward", "guide", "warden", "usher", "crowd marshal"]
        }
      }
    ],
    "triage": [
      {
        "key": "total_patients",
        "label": "Total Patients",
        "type": "number",
        "initial_value": 80,
        "behavior": "static",
        "visible_to": "all"
      },
      {
        "key": "triage_processed",
        "label": "Patients Processed",
        "type": "number",
        "initial_value": 0,
        "behavior": "time_rate",
        "visible_to": "trainer_only",
        "config": {
          "base_rate_per_min": 8,
          "cap_key": "total_patients",
          "robustness_affects": true,
          "robustness_low_mult": 0.5,
          "robustness_high_mult": 1.25,
          "impact_sensitive": true,
          "rate_modifier_key": "treatment_rate_modifier"
        }
      },
      {
        "key": "treatment_rate_modifier",
        "label": "Treatment Rate Modifier",
        "type": "number",
        "initial_value": 1,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "patients_being_treated",
        "label": "Patients Being Treated",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all",
        "config": {
          "source_pool_key": "total_patients",
          "rate_key": "triage_processed",
          "split_fractions": {
            "deaths_on_site": 0.12,
            "handed_over_to_hospital": 0.4
          },
          "split_fractions_low": {
            "deaths_on_site": 0.25,
            "handed_over_to_hospital": 0.2
          },
          "split_fractions_high": {
            "deaths_on_site": 0.05,
            "handed_over_to_hospital": 0.6
          }
        }
      },
      {
        "key": "patients_waiting",
        "label": "Patients Waiting",
        "type": "number",
        "initial_value": 80,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "handed_over_to_hospital",
        "label": "Handed Over to Hospital",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "deaths_on_site",
        "label": "Deaths on Site",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "supply_request_made",
        "label": "Supply Request Made",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": {
          "keywords": ["supply", "request", "tourniquet", "stretcher"]
        }
      }
    ],
    "media": [
      {
        "key": "public_sentiment",
        "label": "Public Sentiment",
        "type": "number",
        "initial_value": 5,
        "behavior": "state_effect",
        "visible_to": "all"
      },
      {
        "key": "media_protocol_score",
        "label": "Protocol Adherence",
        "type": "number",
        "initial_value": 0,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "statements_issued",
        "label": "Statements Issued",
        "type": "number",
        "initial_value": 0,
        "behavior": "decision_increment",
        "visible_to": "all",
        "config": {
          "keywords": ["statement", "press", "announce", "release"]
        }
      },
      {
        "key": "misinformation_addressed_count",
        "label": "Misinformation Addressed",
        "type": "number",
        "initial_value": 0,
        "behavior": "decision_increment",
        "visible_to": "all",
        "config": {
          "keywords": ["debunk", "counter", "correct", "misinformation"]
        }
      },
      {
        "key": "unaddressed_misinformation_count",
        "label": "Unaddressed Misinformation",
        "type": "number",
        "initial_value": 0,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "first_statement_issued",
        "label": "First Statement Issued",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": {
          "keywords": ["statement", "press", "announce", "release"]
        }
      },
      {
        "key": "victim_dignity_respected",
        "label": "Victim Dignity Respected",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": {
          "keywords": [
            "no names",
            "family first",
            "notify family",
            "victim dignity",
            "do not release names"
          ]
        }
      },
      {
        "key": "regular_updates_planned",
        "label": "Regular Updates Planned",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": {
          "keywords": ["30 min", "60 min", "next update", "regular updates", "update every"]
        }
      }
    ],
    "transit_security": [
      {
        "key": "service_halted",
        "label": "Service Halted",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["halt", "stop", "suspend", "service"]
        }
      },
      {
        "key": "attacker_contained",
        "label": "Attacker Contained",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["contained", "neutralised", "apprehended", "subdued"]
        }
      },
      {
        "key": "area_secured",
        "label": "Area Secured",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["secure", "lockdown", "cleared"]
        }
      }
    ]
  }
}
