{
  "id": "stampede_crush",
  "display_name": "Concert stampede / crowd crush",
  "category": "civil_unrest",
  "required_teams": [
    {
      "team_name": "Evacuation",
      "team_description": "Crowd flow control, barrier management, crush prevention, emergency evacuation route coordination, gate control",
      "min_participants": 2,
      "max_participants": 10
    },
    {
      "team_name": "Medical Triage",
      "team_description": "Crush injury triage, compressive asphyxia response, field medical treatment, hospital coordination",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Media & Communications",
      "team_description": "Public communication, crowd guidance via PA and social media, counter-misinformation, event status updates",
      "min_participants": 2,
      "max_participants": 6
    }
  ],
  "environmental_factors": [
    "venue_capacity",
    "exit_width",
    "crowd_density_zones",
    "barrier_placement",
    "slope_grade",
    "weather_conditions",
    "lighting_conditions"
  ],
  "has_adversary": false,
  "adversary_behaviors": [],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "Crowd crush reported at {venue}. People trapped in dense crowd. Reports of people falling. Exits congested.",
      "severity": "critical"
    },
    {
      "timing": "T+3",
      "type": "field_update",
      "template": "Casualties mounting. People unable to breathe in crush zone. Barriers preventing crowd dispersal. Immediate intervention needed.",
      "severity": "critical"
    },
    {
      "timing": "T+5",
      "type": "citizen_call",
      "template": "Multiple exits blocked by crowd pressure. People climbing over barriers. Trampling injuries at bottleneck points.",
      "severity": "critical"
    },
    {
      "timing": "T+8",
      "type": "media_report",
      "template": "Social media footage showing crush. Panic spreading beyond immediate area. Families at home calling emergency lines.",
      "severity": "high"
    },
    {
      "timing": "T+10",
      "type": "field_update",
      "template": "Triage overwhelmed. Compressive asphyxia cases require immediate intervention. Field hospital capacity at limit.",
      "severity": "critical"
    },
    {
      "timing": "T+15",
      "type": "resource_shortage",
      "template": "Hospital surge underway. Ambulance staging full. Additional resources requested. Mutual aid activated.",
      "severity": "high"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "open_barriers_vs_controlled_flow",
      "keywords": ["open", "barriers", "remove", "controlled", "flow"],
      "trigger_condition": "when crowd management decides between opening all barriers or maintaining controlled flow",
      "inject_template": "Open barriers to relieve pressure? Risk of secondary surge. Controlled flow maintains order but people still trapped."
    },
    {
      "branch_id": "cancel_event_vs_pause",
      "keywords": ["cancel", "stop", "pause", "continue"],
      "trigger_condition": "when event security decides to cancel, pause, or continue the event",
      "inject_template": "Cancel event? Entire crowd moves at once. Pause? Crowd confusion. Continue? Risk of worsening crush in other areas."
    },
    {
      "branch_id": "reverse_crowd_direction",
      "keywords": ["reverse", "redirect", "alternative", "route"],
      "trigger_condition": "when evacuation or crowd management redirects crowd flow",
      "inject_template": "Reverse crowd direction? Counter-flow risk. Open alternative routes? May spread problem. PA announcement to redirect?"
    }
  ],
  "compatible_settings": ["stadium", "concert", "festival", "subway", "mall", "street"],
  "compatible_terrains": ["urban", "coastal", "rural"],
  "condition_keys": [
    {
      "key": "crowd_management_no_barrier_decision",
      "meaning": "No decision matches barrier/gate/flow keywords",
      "team": "crowd_management"
    },
    {
      "key": "crowd_management_barriers_opened",
      "meaning": "crowd_management_state.barriers_opened === true",
      "team": "crowd_management",
      "state_path": "crowd_management_state.barriers_opened",
      "negate": false
    },
    {
      "key": "evacuation_no_flow_control_decision",
      "meaning": "No decision matches flow/egress/route keywords",
      "team": "evacuation"
    },
    {
      "key": "event_security_event_not_stopped",
      "meaning": "event_security_state.event_stopped !== true",
      "team": "event_security",
      "state_path": "event_security_state.event_stopped",
      "negate": true
    },
    {
      "key": "media_no_statement_by_T8",
      "meaning": "elapsedMinutes >= 8 and no statement",
      "team": "media"
    }
  ],
  "keyword_patterns": [
    {
      "category": "Barrier management (crowd mgmt)",
      "keywords": ["barrier", "open", "remove", "gate", "fence", "crush barrier"],
      "state_key": "crowd_management_state.barriers_opened"
    },
    {
      "category": "Crowd reversal (crowd mgmt)",
      "keywords": ["reverse", "redirect", "counter-flow", "alternative route"],
      "state_key": "crowd_management_state.crowd_redirected"
    },
    {
      "category": "Flow control (evac)",
      "keywords": ["flow", "bottleneck", "stagger", "egress", "congestion"],
      "state_key": "evacuation_state.flow_control_decided"
    },
    {
      "category": "Event stop (event security)",
      "keywords": ["cancel", "stop", "halt", "pause", "end event"],
      "state_key": "event_security_state.event_stopped"
    },
    {
      "category": "PA announcement (media/crowd mgmt)",
      "keywords": ["announce", "PA", "public address", "broadcast", "loudspeaker"],
      "state_key": "media_state.pa_announcement_made"
    },
    {
      "category": "Statement (media)",
      "keywords": ["statement", "press", "announce", "release"],
      "state_key": "media_state.first_statement_issued"
    }
  ],
