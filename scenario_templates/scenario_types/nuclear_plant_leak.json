{
  "id": "nuclear_plant_leak",
  "display_name": "Nuclear plant leak / radiation release",
  "category": "industrial_disaster",
  "required_teams": [
    {
      "team_name": "Evacuation",
      "team_description": "Multi-ring evacuation (2km/10km/30km progressive), shelter-in-place coordination, KI distribution, exclusion zone enforcement, traffic management",
      "min_participants": 2,
      "max_participants": 10
    },
    {
      "team_name": "Fire Safety",
      "team_description": "Radiological decontamination, HAZMAT containment, hot zone management, reactor systems support, water runoff control, radiation monitoring",
      "min_participants": 2,
      "max_participants": 10
    },
    {
      "team_name": "Medical Triage",
      "team_description": "Contamination screening, acute radiation syndrome triage, internal contamination assessment, dose estimation, radiation-specific treatment protocols",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Media & Communications",
      "team_description": "INES level declaration, public advisory (shelter/evacuate/iodine), counter-misinformation, regulatory liaison (IAEA, national nuclear authority)",
      "min_participants": 2,
      "max_participants": 6
    }
  ],
  "environmental_factors": [
    "reactor_type",
    "containment_integrity",
    "release_type",
    "wind_direction",
    "plume_trajectory",
    "rainfall_risk",
    "groundwater_proximity",
    "population_density_rings",
    "time_since_scram",
    "backup_power_status"
  ],
  "has_adversary": false,
  "adversary_behaviors": [],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "Radiation alarm triggered at {venue}. Automatic SCRAM initiated. Elevated readings detected inside containment building. Cause unknown — loss of coolant suspected.",
      "severity": "critical"
    },
    {
      "timing": "T+5",
      "type": "field_update",
      "template": "Containment pressure rising above design limits. Potential atmospheric release imminent. Wind modelling shows plume trajectory toward populated area to the south-east.",
      "severity": "critical"
    },
    {
      "timing": "T+10",
      "type": "intel_brief",
      "template": "Confirmed release — noble gases and iodine-131 detected outside perimeter fence. Dose rate at plant boundary: 50 µSv/hr and rising. Source term assessment urgently needed.",
      "severity": "critical"
    },
    {
      "timing": "T+20",
      "type": "field_update",
      "template": "Plume modelling shows residential areas within 10 km in release path. KI distribution and evacuation radius decision urgent. Schools in fallout zone requesting guidance.",
      "severity": "critical"
    },
    {
      "timing": "T+30",
      "type": "intel_brief",
      "template": "Rain forecast within 2 hours — washout would concentrate contamination on ground and in water supply. Agricultural zone downwind. Water supply restriction and food chain interdiction decisions needed.",
      "severity": "high"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "evacuation_radius",
      "keywords": ["evacuate", "radius", "2km", "10km", "30km", "zone", "ring"],
      "trigger_condition": "when command decides on evacuation radius — 2km precautionary, 10km protective, or 30km extended",
      "inject_template": "Evacuation radius decision needed. 2 km precautionary? 10 km protective? 30 km extended? Each ring multiplies evacuee count and resource demand exponentially."
    },
    {
      "branch_id": "iodine_distribution",
      "keywords": ["iodine", "KI", "potassium iodide", "tablets", "thyroid", "prophylaxis"],
      "trigger_condition": "when decision is made on KI distribution — pre-distribute or wait for confirmed thyroid dose pathway",
      "inject_template": "KI distribution decision. Pre-distribute to all within 30 km (logistically massive) or wait for confirmed thyroid dose pathway (risk delayed protection)?"
    },
    {
      "branch_id": "ines_declaration",
      "keywords": ["INES", "level", "declare", "classification", "scale", "international"],
      "trigger_condition": "when decision is made to declare INES level (4/5/6/7)",
      "inject_template": "INES level classification needed. Level 4 (local consequences) or higher? Declaration triggers international response protocols and shapes global media narrative."
    },
    {
      "branch_id": "shelter_vs_evacuate",
      "keywords": ["shelter", "stay indoors", "shelter in place", "wind shift", "plume"],
      "trigger_condition": "when wind shift makes shelter-in-place potentially safer than evacuation through the plume",
      "inject_template": "Wind shift detected. Evacuees on Route 7 may drive directly through the plume. Shelter-in-place may now be safer for some zones. Reverse the evacuation order?"
    },
    {
      "branch_id": "water_supply_restriction",
      "keywords": ["water", "supply", "restrict", "reservoir", "contamination", "drinking"],
      "trigger_condition": "when decision is made to restrict surface water sources",
      "inject_template": "Surface water sources in the plume path may be contaminated. Restrict supply and switch to reserves? Population affected: estimated 80,000."
    },
    {
      "branch_id": "food_chain_interdiction",
      "keywords": [
        "food",
        "dairy",
        "produce",
        "agriculture",
        "ban",
        "interdiction",
        "livestock",
        "milk"
      ],
      "trigger_condition": "when decision is made to ban dairy and produce from affected agricultural zones",
      "inject_template": "Iodine-131 concentrates in dairy via pasture-cow-milk pathway. Ban dairy and fresh produce from the fallout zone? Farmers demanding clarity."
    }
  ],
  "compatible_settings": ["power_plant", "industrial", "government"],
  "compatible_terrains": ["rural", "coastal", "urban", "desert"],
  "multi_storey": false,
  "condition_keys": [
    {
      "key": "source_term_not_assessed",
      "meaning": "No source term characterisation completed by expected time",
      "team": "radiation_safety"
    },
    {
      "key": "reactor_scram_not_verified",
      "meaning": "Reactor SCRAM not verified or coolant status unknown",
      "team": "plant_operations"
    },
    {
      "key": "containment_venting_not_decided",
      "meaning": "Containment pressure critical but no venting decision made",
      "team": "plant_operations"
    },
    {
      "key": "evacuation_no_decision",
      "meaning": "No evacuation or shelter-in-place decision made",
      "team": "evacuation"
    },
    {
      "key": "ki_not_distributed_by_T20",
      "meaning": "elapsedMinutes >= 20 and KI distribution not ordered despite confirmed iodine release",
      "team": "evacuation"
    },
    {
      "key": "decon_not_established",
      "meaning": "No decontamination stations established",
      "team": "fire_hazmat"
    },
    {
      "key": "media_no_statement_by_T12",
      "meaning": "elapsedMinutes >= 12 and no public statement issued",
      "team": "media"
    },
    {
      "key": "ines_not_declared_by_T25",
      "meaning": "elapsedMinutes >= 25 and INES level not declared",
      "team": "media"
    }
  ],
  "keyword_patterns": [
    {
      "category": "Source Term (radiation_safety)",
      "keywords": ["source term", "characterize", "isotope", "spectrum", "activity"],
      "state_key": "radiation_safety_state.source_term_assessed"
    },
    {
      "category": "SCRAM (plant_operations)",
      "keywords": ["SCRAM", "shutdown", "trip", "control rods", "reactor shutdown"],
      "state_key": "plant_operations_state.reactor_scrammed"
    },
    {
      "category": "Venting (plant_operations)",
      "keywords": ["vent", "pressure relief", "release", "containment vent"],
      "state_key": "plant_operations_state.venting_authorized"
    },
    {
      "category": "Evacuation (evacuation)",
      "keywords": ["evacuate", "evacuation", "clear", "move out", "bus"],
      "state_key": "evacuation_state.evacuation_ordered"
    },
    {
      "category": "KI Distribution (evacuation)",
      "keywords": ["iodine", "KI", "potassium iodide", "tablets"],
      "state_key": "evacuation_state.ki_distribution_ordered"
    },
    {
      "category": "Decontamination (fire_hazmat)",
      "keywords": ["decontamination", "decon", "wash", "screening"],
      "state_key": "fire_hazmat_state.decon_stations_operational"
    },
    {
      "category": "INES Declaration (media)",
      "keywords": ["INES", "level", "declare", "classification", "nuclear scale"],
      "state_key": "media_state.ines_level_declared"
    },
    {
      "category": "Statement (media)",
      "keywords": ["statement", "press", "announce", "release", "advisory"],
      "state_key": "media_state.first_statement_issued"
    },
    {
      "category": "Exclusion Zone (police)",
      "keywords": ["exclusion", "cordon", "perimeter", "restrict", "zone"],
      "state_key": "police_state.exclusion_zone_enforced"
    }
  ],
