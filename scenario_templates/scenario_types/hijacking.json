{
  "id": "hijacking",
  "display_name": "Hijacking",
  "category": "terrorism",
  "required_teams": [
    {
      "team_name": "Evacuation",
      "team_description": "Perimeter establishment, area lockdown, passenger evacuation post-resolution, crowd management",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Medical Triage",
      "team_description": "Standby medical support, hostage medical assessment post-resolution, casualty stabilization",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "Media & Communications",
      "team_description": "Public communication, media management, misinformation control, press management",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "Pursuit & Investigation",
      "team_description": "Tactical response, hijacker negotiation, perpetrator identification, real-time surveillance, interception planning",
      "min_participants": 2,
      "max_participants": 10,
      "is_investigative": true
    }
  ],
  "environmental_factors": [
    "vehicle_type",
    "passenger_count",
    "route_trajectory",
    "fuel_status",
    "hostage_conditions"
  ],
  "has_adversary": true,
  "adversary_behaviors": [
    "demand_escalation",
    "route_diversion",
    "hostage_threat",
    "media_exploitation",
    "barricade"
  ],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "Hijacking reported at {venue}. Vehicle/aircraft seized. Number of hostages and perpetrators unknown.",
      "severity": "critical"
    },
    {
      "timing": "T+5",
      "type": "intel_brief",
      "template": "Initial demands received. Perpetrators appear organised. Hostage count being confirmed.",
      "severity": "high"
    },
    {
      "timing": "T+10",
      "type": "field_update",
      "template": "Perpetrators threaten escalation if demands not met within deadline. Hostage welfare concerns rising.",
      "severity": "critical"
    },
    {
      "timing": "T+15",
      "type": "media_report",
      "template": "News outlets broadcasting live. Social media speculation on perpetrator identity. Public anxiety growing.",
      "severity": "high"
    },
    {
      "timing": "T+20",
      "type": "field_update",
      "template": "Hostage released as goodwill gesture — or hostage condition deteriorating. Tactical window assessment needed.",
      "severity": "high"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "negotiate",
      "keywords": ["negotiate", "talk", "demand", "communicate"],
      "trigger_condition": "when negotiation team establishes contact with hijackers",
      "inject_template": "Contact established. Hijackers present demands. Negotiation strategy must be decided."
    },
    {
      "branch_id": "tactical_entry",
      "keywords": ["breach", "assault", "tactical", "storm", "entry"],
      "trigger_condition": "when command authorises tactical intervention",
      "inject_template": "Tactical intervention authorised. Entry team preparing. Risk to hostages assessed."
    },
    {
      "branch_id": "media_statement",
      "keywords": ["statement", "press", "public"],
      "trigger_condition": "when media team issues public statement",
      "inject_template": "Public statement issued. Media scrutiny intensifies."
    }
  ],
  "compatible_settings": ["airport", "train", "subway", "street", "hotel", "open_field"],
  "compatible_terrains": ["urban", "coastal", "rural", "desert"],
  "multi_storey": false,
  "condition_keys": [
    {
      "key": "police_no_perimeter_decision",
      "meaning": "No decision matches perimeter/cordon keywords",
      "team": "police"
    },
    {
      "key": "police_perimeter_established",
      "meaning": "police_state.perimeter_established === true",
      "team": "police"
    },
    {
      "key": "negotiation_not_initiated",
      "meaning": "negotiation_state.contact_established !== true",
      "team": "negotiation"
    },
    {
      "key": "media_no_statement_by_T12",
      "meaning": "elapsedMinutes >= 12 and no statement",
      "team": "media"
    }
  ],
  "keyword_patterns": [
    {
      "category": "Perimeter (police)",
      "keywords": ["perimeter", "cordon", "secure", "contain", "lockdown"],
      "state_key": "police_state.perimeter_established"
    },
    {
      "category": "Contact (negotiation)",
      "keywords": ["contact", "negotiate", "talk", "communicate", "demand"],
      "state_key": "negotiation_state.contact_established"
    },
    {
      "category": "Statement (media)",
      "keywords": ["statement", "press", "announce", "release"],
      "state_key": "media_state.first_statement_issued"
    }
  ],
  "team_counter_definitions": {
    "police": [
      {
        "key": "perimeter_established",
        "label": "Perimeter Established",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["perimeter", "cordon", "secure", "contain", "lockdown"]
        }
      },
      {
        "key": "tactical_team_ready",
        "label": "Tactical Team Ready",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["tactical", "armed", "ready", "breach", "assault"]
        }
      },
      {
        "key": "armed_units",
        "label": "Armed Units",
        "type": "number",
        "initial_value": 0,
        "behavior": "state_effect",
        "visible_to": "all"
      },
      {
        "key": "route_blocked",
        "label": "Route Blocked",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["route", "block", "divert", "intercept", "roadblock"]
        }
      }
    ],
    "negotiation": [
      {
        "key": "contact_established",
        "label": "Contact Established",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["contact", "negotiate", "communicate", "talk"]
        }
      },
      {
        "key": "demands_received",
        "label": "Demands Received",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["demand", "ransom", "request", "condition"]
        }
      },
      {
        "key": "sessions_count",
        "label": "Negotiation Sessions",
        "type": "number",
        "initial_value": 0,
        "behavior": "decision_increment",
        "visible_to": "all",
        "config": {
          "keywords": ["session", "negotiation", "round", "talk"]
        }
      },
      {
        "key": "deadline_extended",
        "label": "Deadline Extended",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["deadline", "extend", "more time", "delay"]
        }
      }
    ],
    "intelligence": [
      {
        "key": "perpetrator_count_known",
        "label": "Perpetrator Count Confirmed",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["count", "confirm", "identified", "perpetrator"]
        }
      },
      {
        "key": "inside_intel",
        "label": "Inside Intelligence Available",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": {
          "keywords": ["inside", "intel", "surveillance", "camera", "feed"]
        }
      },
      {
        "key": "vehicle_tracked",
        "label": "Vehicle Tracked",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["tracked", "radar", "GPS", "location", "transponder"]
        }
      },
      {
        "key": "passenger_manifest_obtained",
        "label": "Passenger Manifest Obtained",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["manifest", "passenger list", "names", "roster", "headcount"]
        }
      }
    ],
    "media": [
      {
        "key": "public_sentiment",
        "label": "Public Sentiment",
        "type": "number",
        "initial_value": 5,
        "behavior": "state_effect",
        "visible_to": "all"
      },
      {
        "key": "media_protocol_score",
        "label": "Protocol Adherence",
        "type": "number",
        "initial_value": 0,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "statements_issued",
        "label": "Statements Issued",
        "type": "number",
        "initial_value": 0,
        "behavior": "decision_increment",
        "visible_to": "all",
        "config": {
          "keywords": ["statement", "press", "announce", "release"]
        }
      },
      {
        "key": "first_statement_issued",
        "label": "First Statement Issued",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": {
          "keywords": ["statement", "press", "announce", "release"]
        }
      },
      {
        "key": "misinformation_addressed_count",
        "label": "Misinformation Addressed",
        "type": "number",
        "initial_value": 0,
        "behavior": "decision_increment",
        "visible_to": "all",
        "config": {
          "keywords": ["debunk", "counter", "correct", "misinformation", "rumour"]
        }
      },
      {
        "key": "unaddressed_misinformation_count",
        "label": "Unaddressed Misinformation",
        "type": "number",
        "initial_value": 0,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "victim_dignity_respected",
        "label": "Victim Dignity Respected",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": {
          "keywords": [
            "no names",
            "family first",
            "notify family",
            "victim dignity",
            "do not release names"
          ]
        }
      },
      {
        "key": "regular_updates_planned",
        "label": "Regular Updates Planned",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": {
          "keywords": ["30 min", "60 min", "next update", "regular updates", "update every"]
        }
      }
    ],
    "triage": [
      {
        "key": "total_patients",
        "label": "Total Patients",
        "type": "number",
        "initial_value": 160,
        "behavior": "static",
        "visible_to": "all"
      },
      {
        "key": "triage_processed",
        "label": "Patients Processed",
        "type": "number",
        "initial_value": 0,
        "behavior": "time_rate",
        "visible_to": "trainer_only",
        "config": {
          "base_rate_per_min": 8,
          "cap_key": "total_patients",
          "robustness_affects": true,
          "robustness_low_mult": 0.5,
          "robustness_high_mult": 1.25,
          "impact_sensitive": true,
          "rate_modifier_key": "treatment_rate_modifier"
        }
      },
      {
        "key": "treatment_rate_modifier",
        "label": "Treatment Rate Modifier",
        "type": "number",
        "initial_value": 1,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "patients_being_treated",
        "label": "Patients Being Treated",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all",
        "config": {
          "source_pool_key": "total_patients",
          "rate_key": "triage_processed",
          "split_fractions": {
            "deaths_on_site": 0.1,
            "handed_over_to_hospital": 0.45
          },
          "split_fractions_low": {
            "deaths_on_site": 0.2,
            "handed_over_to_hospital": 0.25
          },
          "split_fractions_high": {
            "deaths_on_site": 0.05,
            "handed_over_to_hospital": 0.6
          }
        }
      },
      {
        "key": "patients_waiting",
        "label": "Patients Waiting",
        "type": "number",
        "initial_value": 160,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "handed_over_to_hospital",
        "label": "Handed Over to Hospital",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "deaths_on_site",
        "label": "Deaths on Site",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "medical_standby",
        "label": "Medical Standby Active",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["standby", "medical", "ambulance", "triage", "prepare"]
        }
      },
      {
        "key": "casualties",
        "label": "Casualties",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      }
    ]
  }
}
