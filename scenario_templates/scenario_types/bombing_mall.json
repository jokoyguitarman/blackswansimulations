{
  "id": "bombing_mall",
  "display_name": "Mall bombing",
  "category": "terrorism",
  "required_teams": [
    {
      "team_name": "Evacuation",
      "team_description": "Vertical and horizontal evacuation, stairwell flow control, store lockdown, PA announcements, perimeter control",
      "min_participants": 2,
      "max_participants": 10
    },
    {
      "team_name": "Hazards / Fire / Rescue",
      "team_description": "Fire containment, smoke control, structural assessment, search and rescue, debris clearance",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Medical Triage",
      "team_description": "Blast injury triage, casualty prioritization, smoke-free triage site coordination, casualty stabilization",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Media & Communications",
      "team_description": "Public communication, counter misinformation, press management, family reunification info",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "Bomb Squad / EOD",
      "team_description": "Secondary device sweep, render safe procedures, forensic IED analysis, blast cordon assessment",
      "min_participants": 2,
      "max_participants": 6
    }
  ],
  "environmental_factors": [
    "vertical_evacuation",
    "smoke_spread",
    "stairwell_capacity",
    "escalator_elevator_safety"
  ],
  "has_adversary": true,
  "adversary_behaviors": [
    "propaganda_operative",
    "suicide_attacker_at_crowd_density",
    "fleeing_through_mall",
    "blend_in_crowd"
  ],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "A sudden explosion occurs at {venue} central atrium. Smoke, dust, and debris obscure visibility. Panic spreads rapidly across multiple floors. People run toward stairwells and exits. The extent of casualties is unknown.",
      "severity": "critical"
    },
    {
      "timing": "T+4",
      "type": "field_update",
      "template": "Secondary fire reported. Smoke spreading to upper floors. Volunteers return with inconsistent casualty counts.",
      "severity": "high"
    },
    {
      "timing": "T+4",
      "type": "field_update",
      "template": "Escalator/elevator hazard. Structural damage suspected. Use stairwells only. Do not use elevators.",
      "severity": "high"
    },
    {
      "timing": "T+6",
      "type": "field_update",
      "template": "Stairwell congestion. Child fallen. Trampling risk. Immediate flow control needed.",
      "severity": "high"
    },
    {
      "timing": "T+8",
      "type": "field_update",
      "template": "Emergency services delayed. Traffic congestion. C2E and Fire must manage longer independently.",
      "severity": "high"
    },
    {
      "timing": "T+10",
      "type": "media_report",
      "template": "Viral video circulates online. Poor visibility leads to false accusations. Online commenters claim attackers from specific community. Video going viral rapidly.",
      "severity": "critical"
    },
    {
      "timing": "T+12",
      "type": "media_report",
      "template": "Journalist arrives before emergency services. Begins filming casualties. Asks leading questions. Posting unverified observations online.",
      "severity": "high"
    },
    {
      "timing": "T+15",
      "type": "field_update",
      "template": "Crowd tension escalates. Dispute erupts near evacuation zone. Attendee shouts accusations. Minor altercation. Volunteer confronted.",
      "severity": "critical"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "evacuate_together",
      "keywords": ["evacuate", "together", "everyone"],
      "trigger_condition": "when evacuation team decides to evacuate all together without segregation",
      "inject_template": "Evacuation proceeds without demographic segregation. All evacuees use same routes."
    },
    {
      "branch_id": "segregate",
      "keywords": ["separate", "segregate", "demographic"],
      "trigger_condition": "when evacuation team or coordination centre decides to segregate by demographic",
      "inject_template": "A fearful resident requests segregation. Evacuation team must decide: comply with discriminatory request or refuse and evacuate together."
    },
    {
      "branch_id": "media_statement",
      "keywords": ["statement", "misinformation", "counter"],
      "trigger_condition": "when media team submits first public statement",
      "inject_template": "Public statement submitted. Does it address misinformation? Does it cite verified facts? Designated spokesperson?"
    }
  ],
  "compatible_settings": ["mall"],
  "compatible_terrains": ["urban"],
  "multi_storey": true,
  "condition_keys": [
    {
      "key": "evacuation_no_flow_control_decision",
      "meaning": "No decision matches flow/bottleneck/exit capacity keywords",
      "team": "evacuation"
    },
    {
      "key": "evacuation_flow_control_decided",
      "meaning": "evacuation_state.flow_control_decided === true",
      "team": "evacuation"
    },
    {
      "key": "evacuation_exit_bottleneck_active",
      "meaning": "exits_congested non-empty (unmanaged)",
      "team": "evacuation"
    },
    {
      "key": "evacuation_coordination_established",
      "meaning": "evacuation_state.coordination_with_triage === true",
      "team": "evacuation"
    },
    {
      "key": "triage_zone_established_as_incident_location",
      "meaning": "Decision mentions triage zone",
      "team": "triage"
    },
    {
      "key": "triage_supply_critical",
      "meaning": "triage_state.supply_level === critical",
      "team": "triage"
    },
    {
      "key": "triage_surge_active",
      "meaning": "triage_state.surge_active === true",
      "team": "triage"
    },
    {
      "key": "triage_no_prioritisation_decision",
      "meaning": "No decision matches prioritisation keywords",
      "team": "triage"
    },
    {
      "key": "triage_prioritisation_decided",
      "meaning": "triage_state.prioritisation_decided === true",
      "team": "triage"
    },
    {
      "key": "media_statement_issued",
      "meaning": "media_state.first_statement_issued === true",
      "team": "media"
    },
    {
      "key": "media_no_statement_by_T12",
      "meaning": "elapsedMinutes >= 12 and no statement",
      "team": "media"
    },
    {
      "key": "media_misinformation_addressed",
      "meaning": "media_state.misinformation_addressed === true",
      "team": "media"
    }
  ],
  "keyword_patterns": [
    {
      "category": "Flow control (evac)",
      "keywords": ["flow", "bottleneck", "stagger", "congestion", "egress", "exit capacity"],
      "state_key": "evacuation_state.flow_control_decided"
    },
    {
      "category": "Supply/equipment (triage)",
      "keywords": ["supply", "request", "tourniquet", "stretcher", "triage tag", "shortage"],
      "state_key": "triage_state.supply_request_made"
    },
    {
      "category": "Prioritisation (triage)",
      "keywords": [
        "prioritise",
        "critical first",
        "severity",
        "triage protocol",
        "red",
        "yellow",
        "green"
      ],
      "state_key": "triage_state.prioritisation_decided"
    },
    {
      "category": "Statement (media)",
      "keywords": ["statement", "press", "announce", "release"],
      "state_key": "media_state.first_statement_issued"
    },
    {
      "category": "Misinformation (media)",
      "keywords": ["debunk", "counter", "correct", "misinformation", "rumour", "narrative"],
      "state_key": "media_state.misinformation_addressed"
    }
  ],
