            "notify family",
            "victim dignity",
            "do not release names"
          ]
        }
      },
      {
        "key": "regular_updates_planned",
        "label": "Regular Updates Planned",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": {
          "keywords": ["30 min", "60 min", "next update", "regular updates", "update every"]
        }
      }
    ],
    "fire_hazmat": [
      {
        "key": "agent_identified",
        "label": "Agent Identified",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["identified", "agent", "chemical", "substance", "detected"]
        }
      },
      {
        "key": "ventilation_managed",
        "label": "Ventilation Managed",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["ventilation", "hvac", "air flow", "shut down", "contain"]
        }
      },
      {
        "key": "hot_zone_established",
        "label": "Hot Zone Established",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["hot zone", "exclusion", "hazard zone", "cordon"]
