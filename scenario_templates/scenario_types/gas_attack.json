{
  "id": "gas_attack",
  "display_name": "Gas attack",
  "category": "terrorism",
  "required_teams": [
    {
      "team_name": "evacuation",
      "team_description": "Evacuate affected area, manage decontamination flow",
      "min_participants": 2,
      "max_participants": 10
    },
    {
      "team_name": "triage",
      "team_description": "Triage respiratory injuries, coordinate decon",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "media",
      "team_description": "Manage media, prevent panic",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "fire_hazmat",
      "team_description": "Hazmat response, ventilation, substance identification",
      "min_participants": 2,
      "max_participants": 8
    }
  ],
  "environmental_factors": ["enclosed_space", "ventilation", "station_vs_tunnel", "decon_site"],
  "adversary_behaviors": ["package_placement", "perpetrator_may_have_left"],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "Gas or unknown substance reported at {venue}. People experiencing respiratory distress. Enclosed space; ventilation limited.",
      "severity": "critical"
    },
    {
      "timing": "T+4",
      "type": "field_update",
      "template": "Substance spreading through carriages/area. Ventilation decision needed. Evacuate or contain?",
      "severity": "high"
    },
    {
      "timing": "T+8",
      "type": "intel_brief",
      "template": "Hazmat assessment: substance unknown. Decontamination site required. Fire/Hazmat coordinating.",
      "severity": "high"
    },
    {
      "timing": "T+12",
      "type": "resource_shortage",
      "template": "Decon supplies limited. Triage prioritising respiratory cases. Hospital surge expected.",
      "severity": "high"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "evacuate_vs_contain",
      "keywords": ["evacuate", "contain", "ventilation"],
      "trigger_condition": "when Fire/Hazmat decides evacuate vs contain and ventilate",
      "inject_template": "Ventilate and risk spread? Or contain and risk exposure to those inside?"
    },
    {
      "branch_id": "decon_site",
      "keywords": ["decontamination", "decon", "site"],
      "trigger_condition": "when coordination selects decontamination site location",
      "inject_template": "Decon site selection. Upwind? Capacity? Access for ambulances?"
    }
  ],
  "compatible_settings": ["train", "subway", "mall", "office", "stadium", "airport", "government"],
  "compatible_terrains": ["urban", "mountain"],
  "team_counter_definitions": {
    "evacuation": [
      {
        "key": "total_evacuees",
        "label": "Total Evacuees",
        "type": "number",
        "initial_value": 600,
        "behavior": "static",
        "visible_to": "all"
      },
      {
        "key": "evacuated_count",
        "label": "People Evacuated",
        "type": "number",
        "initial_value": 0,
        "behavior": "time_rate",
        "visible_to": "all",
        "config": {
          "base_rate_per_min": 25,
          "cap_key": "total_evacuees",
          "requires_flag": "flow_control_decided",
          "robustness_affects": true,
          "congestion_halves": true,
          "impact_sensitive": true,
          "rate_modifier_key": "evac_rate_modifier",
          "marshal_boost_key": "marshals_deployed",
          "marshal_boost_mult": 1.15
        }
      },
      {
        "key": "evac_rate_modifier",
        "label": "Evacuation Rate Modifier",
        "type": "number",
        "initial_value": 1,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "flow_control_decided",
        "label": "Flow Control Decided",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["flow", "bottleneck", "stagger", "egress", "ventilation route"]
        }
      },
      {
        "key": "marshals_deployed",
        "label": "Marshals / Stewards Deployed",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["marshal", "steward", "guide", "warden", "usher", "crowd marshal"]
        }
      },
      {
        "key": "decontaminated_count",
        "label": "Decontaminated",
        "type": "number",
        "initial_value": 0,
        "behavior": "time_rate",
        "visible_to": "all",
        "config": {
          "base_rate_per_min": 15,
          "cap_key": "total_evacuees",
          "requires_flag": "decon_site_established",
          "robustness_affects": true
        }
      },
      {
        "key": "decon_site_established",
        "label": "Decon Site Established",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "all",
        "config": {
          "keywords": ["decontamination", "decon", "wash", "site"]
        }
      }
    ],
    "triage": [
      {
        "key": "total_patients",
        "label": "Total Patients",
        "type": "number",
        "initial_value": 160,
        "behavior": "static",
        "visible_to": "all"
      },
      {
        "key": "triage_processed",
        "label": "Patients Processed",
        "type": "number",
        "initial_value": 0,
        "behavior": "time_rate",
        "visible_to": "trainer_only",
        "config": {
          "base_rate_per_min": 8,
          "cap_key": "total_patients",
          "robustness_affects": true,
          "robustness_low_mult": 0.5,
          "robustness_high_mult": 1.25,
          "impact_sensitive": true,
          "rate_modifier_key": "treatment_rate_modifier"
        }
      },
      {
        "key": "treatment_rate_modifier",
        "label": "Treatment Rate Modifier",
        "type": "number",
        "initial_value": 1,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "patients_being_treated",
        "label": "Patients Being Treated",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all",
        "config": {
          "source_pool_key": "total_patients",
          "rate_key": "triage_processed",
          "split_fractions": {
            "deaths_on_site": 0.12,
            "handed_over_to_hospital": 0.4
          },
          "split_fractions_low": {
            "deaths_on_site": 0.25,
            "handed_over_to_hospital": 0.2
          },
          "split_fractions_high": {
            "deaths_on_site": 0.05,
            "handed_over_to_hospital": 0.6
          }
        }
      },
      {
        "key": "patients_waiting",
        "label": "Patients Waiting",
        "type": "number",
        "initial_value": 160,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "handed_over_to_hospital",
        "label": "Handed Over to Hospital",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "deaths_on_site",
        "label": "Deaths on Site",
        "type": "number",
        "initial_value": 0,
        "behavior": "derived",
        "visible_to": "all"
      },
      {
        "key": "supply_request_made",
        "label": "Supply Request Made",
        "type": "boolean",
        "initial_value": false,
        "behavior": "decision_toggle",
        "visible_to": "trainer_only",
        "config": {
          "keywords": ["supply", "request", "antidote", "atropine"]
        }
      }
    ],
    "media": [
      {
        "key": "public_sentiment",
        "label": "Public Sentiment",
        "type": "number",
        "initial_value": 5,
        "behavior": "state_effect",
        "visible_to": "all"
      },
      {
        "key": "media_protocol_score",
        "label": "Protocol Adherence",
        "type": "number",
        "initial_value": 0,
        "behavior": "state_effect",
        "visible_to": "trainer_only"
      },
      {
        "key": "statements_issued",
        "label": "Statements Issued",
        "type": "number",
        "initial_value": 0,
        "behavior": "decision_increment",
        "visible_to": "all",
        "config": {
          "keywords": ["statement", "press", "announce", "release"]
        }
      },
      {
        "key": "misinformation_addressed_count",
