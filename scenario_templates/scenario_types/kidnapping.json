{
  "id": "kidnapping",
  "display_name": "Kidnapping",
  "category": "terrorism",
  "required_teams": [
    {
      "team_name": "Evacuation",
      "team_description": "Perimeter lockdown, non-target evacuation, access control around the crisis site",
      "min_participants": 2,
      "max_participants": 8
    },
    {
      "team_name": "Medical Triage",
      "team_description": "Medical standby, hostage medical assessment post-recovery, psychological first aid",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "Media & Communications",
      "team_description": "Media blackout coordination, family liaison, controlled public communication, counter-misinformation",
      "min_participants": 2,
      "max_participants": 6
    },
    {
      "team_name": "Pursuit & Investigation",
      "team_description": "Suspect tracking, hostage negotiation, intel analysis, tactical options assessment, containment decisions",
      "min_participants": 2,
      "max_participants": 10,
      "is_investigative": true
    }
  ],
  "environmental_factors": [
    "ingress_routes",
    "extraction_routes",
    "weather_visibility",
    "perimeter_security"
  ],
  "has_adversary": true,
  "adversary_behaviors": [
    "movement_between_locations",
    "ransom_timing",
    "threat_escalation",
    "vehicle_escape",
    "hostage_as_shield"
  ],
  "inject_templates": [
    {
      "timing": "T+0",
      "type": "field_update",
      "template": "Abduction reported at {venue}. Hostages taken. Perpetrators' location unknown. Number of assailants unclear.",
      "severity": "critical"
    },
    {
      "timing": "T+5",
      "type": "intel_brief",
      "template": "Initial intelligence: perpetrators may have local knowledge. Possible extraction routes: {ingress_vector}. Weather affecting visibility.",
      "severity": "high"
    },
    {
      "timing": "T+10",
      "type": "intel_brief",
      "template": "Ransom demand received. Deadline set. Amount specified. Perpetrators may be monitoring media.",
      "severity": "critical"
    },
    {
      "timing": "T+15",
      "type": "field_update",
      "template": "Intelligence suggests possible extraction route via {ingress_vector}. Perimeter breach risk. Resort security reports movement.",
      "severity": "high"
    },
    {
      "timing": "T+20",
      "type": "political_pressure",
      "template": "Government/headquarters demands update. Pressure to resolve quickly. Media asking for comment.",
      "severity": "high"
    }
  ],
  "decision_branches": [
    {
      "branch_id": "negotiate_vs_assault",
      "keywords": ["negotiate", "assault", "storm"],
      "trigger_condition": "when police/command decides between continued negotiation or tactical assault",
      "inject_template": "Negotiation has stalled. Perpetrators threaten harm. Tactical team reports assault option viable. Decision required."
    },
    {
      "branch_id": "media_blackout",
      "keywords": ["blackout", "silence", "release", "media"],
      "trigger_condition": "when coordination centre decides on media blackout vs controlled release",
      "inject_template": "Media requesting information. Perpetrators may be monitoring. Blackout could buy time; release could reduce speculation."
    }
  ],
  "setting_overrides": {
    "resort": {
      "ingress_vectors": ["jungle_path", "ocean", "direct_assault"],
      "additional_env_factors": ["tide", "jungle_visibility", "resort_perimeter"]
    },
    "hotel": {
      "ingress_vectors": ["lobby", "service_entrance", "room_invasion"],
      "additional_env_factors": ["floor_layout", "room_access"]
    }
  },
  "compatible_settings": ["resort", "hotel", "open_field", "office", "campus", "street"],
  "compatible_terrains": ["jungle", "coastal", "mountain", "urban"],
  "condition_keys": [
    {
      "key": "no_perimeter_establishment_decision",
      "meaning": "No decision matches perimeter/cordon keywords",
      "team": "police"
    },
    {
      "key": "official_public_statement_issued",
      "meaning": "At least one executed decision matches statement/public",
      "team": "media"
    },
    {
      "key": "police_perimeter_not_established",
      "meaning": "police_state.perimeter_established !== true",
      "team": "police",
      "state_path": "police_state.perimeter_established",
      "negate": true
    },
    {
      "key": "negotiation_not_initiated",
      "meaning": "negotiation_state.negotiation_initiated !== true",
      "team": "negotiation",
      "state_path": "negotiation_state.negotiation_initiated",
      "negate": true
    }
  ],
  "keyword_patterns": [
    {
      "category": "Perimeter (police)",
      "keywords": ["perimeter", "cordon", "secure", "contain"],
      "state_key": "police_state.perimeter_established"
    },
    {
      "category": "Negotiation",
      "keywords": ["negotiate", "hostage", "ransom", "communicate"],
      "state_key": "negotiation_state.negotiation_initiated"
    }
  ],
